        "type": "text"
      },
      {
        "name": "Venue",
        "source": "_Venue",
        "display": "column",
        "type": "text"
      },
      {
        "name": "Running Time",
        "source": "_PerformanceTime(Interval)",
        "display": "column",
        "type": "text"
      },
      {
        "name": "Ticket Price",
        "source": "_SeatPrice",
        "display": "column",
        "type": "text"
      },
      {
        "name": "Program",
        "source": "_Program",
        "display": "column",
        "type": "markdown"
      },
      {
        "name": "Singer",
        "source": "_SingerAbstract",
        "display": "column",
        "type": "markdown"
      },
      {
        "name": "Accompanist",  
        "source": "_AccompaniedPerformer",
        "display": "column",
        "type": "markdown"
      },
      {
