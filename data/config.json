{
  "project": {
    "name": "recital museum",
    "quality": 1
  },
  "loader": {
    "info": "data/info.md",
    "timeline": "data/timeline.csv",
    "items": "data/(0711)reallywanttogohome_filled.csv",
    "voicetype": "data/voicetype.csv",
    "layouts": [
      {
        "title": "Time"
      },
      {
        "title": "Similarity",
        "url": "data/tsne.csv",
        "scale": 1.0
      }
    ],

    "textures": {
      "medium": {
        "size": 256,
        "url": "data/sprites/spritesheet.json"
      },
      "detail": {
        "size": 1024,
        "url": "data/1024/"
      },
      "big": {
        "size": 4096,
        "url": "data/4096/"
      }
    }
  },
  "style": {
    "fontColor": "#ed6f63",
    "fontColorActive": "#eae2cb",
    "fontBackground": "#295b71",
    "textShadow": "3px 3px 0px #101820",
    "canvasBackground": "#2D2926",
    "timelineBackground": "#fff9eb",
    "timelineFontColor": "#000",
    "backgroundHeader": "#035151",
    "fontColorHeader": "#f8774f",
    "detailBackground": "#EEE",
    "infoBackground": "#33444c",
    "infoFontColor": "#fff",
    "searchbarBackground": "#ed6f63"
  },
  "projection": {
    "columns": 6
  },
  "detail": {
    "structure": [
      {
        "name": "Title",
        "source": "_PerformanceTitle",
